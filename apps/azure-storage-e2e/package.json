{
  "name": "@flix-tube/azure-storage-e2e",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "name": "azure-storage-e2e",
    "implicitDependencies": [
      "azure-storage"
    ],
    "targets": {
      "e2e": {
        "executor": "@nx/jest:jest",
